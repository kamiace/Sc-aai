# Local persistence. Defaults to backend/data/swurlz_core.sqlite3
SWRLZ_DATA_DIR=./data

# Optional online Mentor. Leave blank for storage-only/offline backend mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Recommended for any backend reachable beyond localhost.
SWRLZ_API_TOKEN=replace-with-a-long-random-private-token

# Comma-separated web-console origins, or * for local testing.
CORS_ORIGINS=*
