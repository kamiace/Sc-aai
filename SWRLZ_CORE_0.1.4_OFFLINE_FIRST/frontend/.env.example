# Leave blank for a fully local/offline console.
REACT_APP_BACKEND_URL=

# Set true only when the web console and FastAPI backend share one origin.
REACT_APP_USE_SAME_ORIGIN=false

# Must match backend SWURLZ_API_TOKEN when token protection is enabled.
REACT_APP_SWURLZ_API_TOKEN=

# Set true only after placing a newly built APK at public/apk/swurlz-core-debug.apk.
REACT_APP_APK_AVAILABLE=false
